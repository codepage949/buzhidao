# 번역 소스 언어 설정 (en / ch)
SOURCE=en
# OCR 인식 신뢰도 임계값 (0.0 ~ 1.0)
SCORE_THRESH=0.5
# AI Gateway API 키
AI_GATEWAY_API_KEY=
# 모델 이름 (예: alibaba/qwen-3-32b)
AI_GATEWAY_MODEL=
# 같은 그룹으로 볼 최대 수평 간격 (픽셀): 같은 줄 내 단어/문자 덩어리 간격
WORD_GAP=20
# 같은 문단으로 볼 최대 줄 간격 (픽셀): 인접 줄 사이 수직 거리 상한
LINE_GAP=15
# OCR 추적 로그/원시 박스 표시 여부 (디버깅용)
OCR_DEBUG_TRACE=false
# OCR server 장치 (cpu / gpu)
OCR_SERVER_DEVICE=cpu
# OCR server 실행 파일 경로. 개발 중에는 지정한 값을 그대로 사용합니다.
# 미지정 시 기본값: ../ocr_server/dist/ocr_server/ocr_server(.exe)
# 배포 빌드에서는 우선 번들 resource dir의 ocr_server(.exe)를 찾고, 없으면 위 기본값을 사용합니다.
# OCR_SERVER_EXECUTABLE=
# OCR server 준비 타임아웃(초)
OCR_SERVER_STARTUP_TIMEOUT_SECS=30
# OCR server 요청 타임아웃(초)
OCR_SERVER_REQUEST_TIMEOUT_SECS=20
# 캡처 단축키 (Tauri Accelerator 포맷, 예: Ctrl+Alt+A / Cmd+Shift+A)
# 수식키(Ctrl/Alt/Shift/Cmd) 없는 단일 키(PrtSc 등)는 OS가 등록을 거부합니다.
# 비워두면 플랫폼 기본값(Windows/Linux: Ctrl+Alt+A, macOS: Cmd+Shift+A)이 사용됩니다.
CAPTURE_SHORTCUT=
