# 번역 소스 언어 설정 (en / ch)
SOURCE=en
# OCR 인식 신뢰도 임계값 (0.0 ~ 1.0)
SCORE_THRESH=0.5
# AI Gateway API 키
AI_GATEWAY_API_KEY=
# 모델 이름 (예: alibaba/qwen-3-32b)
AI_GATEWAY_MODEL=
SYSTEM_PROMPT=다음을 한국어로 번역하세요.
# 같은 그룹으로 볼 최대 수평 간격 (픽셀): 같은 줄 내 단어/문자 덩어리 간격
WORD_GAP=20
# 같은 문단으로 볼 최대 줄 간격 (픽셀): 인접 줄 사이 수직 거리 상한
LINE_GAP=15
# OCR 추적 로그/원시 박스 표시 여부 (디버깅용)
OCR_DEBUG_TRACE=false
# OCR server 장치 (cpu / gpu)
OCR_SERVER_DEVICE=cpu
# OCR server 실행 파일 (PyInstaller 산출물)
OCR_SERVER_EXECUTABLE=../ocr_server/dist/ocr_server/ocr_server.exe
# GPU 빌드 사용 시 예시
# OCR_SERVER_EXECUTABLE=../ocr_server/dist/ocr_server_gpu/ocr_server_gpu.exe
# OCR server 준비 타임아웃(초)
OCR_SERVER_STARTUP_TIMEOUT_SECS=30
# OCR server 요청 타임아웃(초)
OCR_SERVER_REQUEST_TIMEOUT_SECS=20
