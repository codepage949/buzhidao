# 번역 소스 언어 설정 (en / ch)
SOURCE=en
# OCR 인식 신뢰도 임계값 (0.0 ~ 1.0)
SCORE_THRESH=0.5
# AI Gateway API 키
AI_GATEWAY_API_KEY=
# 모델 이름 (예: alibaba/qwen-3-32b)
AI_GATEWAY_MODEL=
# 선택: 시스템 프롬프트 파일 경로 (미설정 시 "다음을 한국어로 번역하세요." 사용)
# SYSTEM_PROMPT_PATH=.system_prompt.txt
# 같은 그룹으로 볼 최대 수평 간격 (픽셀): 같은 줄 내 단어/문자 덩어리 간격
WORD_GAP=20
# 같은 문단으로 볼 최대 줄 간격 (픽셀): 인접 줄 사이 수직 거리 상한
LINE_GAP=15
# det 히트맵 이진화 임계값 (0.0~1.0): 낮을수록 더 많은 텍스트 픽셀 포함, 높을수록 정밀
DET_THRESH=0.2
# det 박스 채택 임계값 (0.0~1.0): 낮을수록 더 많은 박스 채택, 높을수록 고신뢰 박스만 유지
BOX_THRESH=0.4
# OCR 추적 로그/원시 박스 표시 여부 (디버깅용)
OCR_DEBUG_TRACE=false
# OCR backend 선택 (onnx / python_sidecar / paddle_ffi)
OCR_BACKEND=onnx
# python_sidecar backend용 실행 파일 경로 (PyInstaller 산출물 또는 python 래퍼)
# 예: /abs/path/dist/paddle_ocr_sidecar
# PYTHON_OCR_EXECUTABLE=
# paddle-ffi feature 빌드 시 Paddle Inference SDK 루트 경로
# 예: /opt/paddle_inference
# PADDLE_INFERENCE_DIR=
# paddle-ffi feature 빌드 시 원본 Paddle 추론 모델 디렉토리
# 예: /opt/paddle_models
# 내부에 det/cls/rec 하위 디렉토리 또는 det.json/rec.pdiparams 같은 파일이 있어야 함
# PADDLE_MODEL_DIR=
